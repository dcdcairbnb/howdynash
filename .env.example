# Foursquare Places - restaurants, ratings, hours, photos
# Sign up: https://foursquare.com/developers
# Free: 1,000 calls/day (~30,000/month)
FOURSQUARE_API_KEY=

# Google Places API (New) - attractions, points of interest
# Sign up: https://console.cloud.google.com/apis/library/places.googleapis.com
# Free: $200/month credit (covers ~10,000 calls)
GOOGLE_PLACES_KEY=

# Ticketmaster Discovery - concerts, sports, events
# Sign up: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
# Free: 5,000 calls/day
TICKETMASTER_KEY=

# SeatGeek - additional concert/event coverage, catches indie Nashville venues
# Sign up: https://seatgeek.com/account/develop
# Free
SEATGEEK_CLIENT_ID=

# Nashville Open Data (Socrata) - city datasets
# Optional but recommended for higher rate limits
# Sign up: https://data.nashville.gov/profile/edit/developer_settings
NASHVILLE_APP_TOKEN=
