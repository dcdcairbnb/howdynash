# Howdy Nashville environment variables
# Copy this file to .env.local for local dev, or add each key to Vercel
# Project Settings, Environment Variables for production.

# Foursquare Places. Restaurants, ratings, hours, photos.
# Sign up: https://foursquare.com/developers
# Free tier: 1,000 calls/day
FOURSQUARE_API_KEY=

# Google Places API (New). Attractions, hotels, generic search.
# Sign up: https://console.cloud.google.com/apis/library/places.googleapis.com
# Free: $200/month credit (~10,000 calls)
GOOGLE_PLACES_KEY=

# Ticketmaster Discovery. Concerts, sports, events.
# Sign up: https://developer.ticketmaster.com
# Free: 5,000 calls/day
TICKETMASTER_KEY=

# SeatGeek. Indie venue and event coverage.
# Sign up: https://seatgeek.com/account/develop
# Free
SEATGEEK_CLIENT_ID=

# Eventbrite. Community events, festivals, songwriter rounds.
# Sign up: https://www.eventbrite.com
# Account Settings > Developer Links > API Keys
# Free
EVENTBRITE_PRIVATE_TOKEN=

# AviationStack. BNA flight tracker.
# Sign up: https://aviationstack.com
# Free tier: 100 calls/month
AVIATIONSTACK_KEY=

# Anthropic Claude. Powers the AI chat fallback.
# Sign up: https://console.anthropic.com
# Pay-as-you-go. Add $5 minimum credit to start.
ANTHROPIC_API_KEY=

# Nashville Open Data (optional, raises rate limits).
# Sign up: https://data.nashville.gov/profile/edit/developer_settings
NASHVILLE_APP_TOKEN=
